# Local API keys for BOM Builder.
MOUSER_API_KEY=your-mouser-api-key
MOUSER_API_KEYS=your-primary-mouser-api-key,your-backup-mouser-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional local path overrides.
# Leave these unset or blank to use the platform defaults.
BOM_BUILDER_CACHE_DB=/Users/your-user/Library/Caches/bom-builder/mouser_cache.sqlite3
BOM_BUILDER_RESOLUTIONS_FILE=/Users/your-user/.config/bom-builder/resolutions.json
